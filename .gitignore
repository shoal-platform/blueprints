# Shoal blueprints — combined .gitignore
# Covers: Go, Node/JavaScript/TypeScript, Python, Ruby, PHP, .NET (C#), Rust
# Add language-specific entries here as new blueprints are added.

# ---- General ----
.env
.env.*
!.env.example
*.log
.DS_Store
Thumbs.db
.claude

# Editor/IDE
.idea/
.vscode/
*.swp
*.swo

# ---- Go ----
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
coverage.*
*.coverprofile
profile.cov
go.work
go.work.sum
# vendor/

# ---- Node / JavaScript / TypeScript ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
dist/
build/
.next/
.nuxt/
.turbo/
coverage/
*.tsbuildinfo

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.tox/
pip-wheel-metadata/

# ---- Ruby ----
*.gem
.bundle/
vendor/bundle/
.rspec_status

# ---- PHP ----
vendor/
composer.phar
.phpunit.result.cache

# ---- .NET / C# ----
bin/
obj/
*.user
*.suo
project.lock.json
project.fragment.lock.json
artifacts/

# ---- Rust ----
target/
Cargo.lock
**/*.rs.bk
