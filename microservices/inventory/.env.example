# Postgres connection string shared by all three services.
# Neon URLs with ?sslmode=require work as-is.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/dropship

# Listen port
PORT=8082

# How often to look for pending orders / orders ready to ship
POLL_INTERVAL_MS=2000

# How often the simulated supplier sync tops up stock (also retries backorders)
RESTOCK_INTERVAL_MS=15000

# Simulated fulfillment delay before a confirmed order ships
SHIP_DELAY_SECONDS=10
