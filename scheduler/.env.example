# Postgres connection string. Server creates the database + table if missing.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bitcoin

# Port the HTTP server listens on (Cloud Run injects this).
PORT=8080

# Free price API. Defaults to CoinGecko's simple price endpoint (no key needed).
# PRICE_API_URL=https://api.coingecko.com/api/v3/simple/price

# Coin and fiat currency to track.
# COIN_ID=bitcoin
# VS_CURRENCY=usd

# Optional shared secret for the Cloud Scheduler ingest endpoint.
# If set, requests to POST /tasks/fetch-price must send
# "X-Scheduler-Token: <value>". Prefer Cloud Run IAM/OIDC in production.
# SCHEDULER_TOKEN=change-me
