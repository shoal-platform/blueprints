# Postgres connection string. With Neon, copy it from the dashboard, e.g.
# DATABASE_URL=postgres://user:password@ep-xxx.eu-west-2.aws.neon.tech/forum?sslmode=require
# The server creates the schema on startup. It also tries to create the
# database itself and skips gracefully if the role isn't allowed to (Neon).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/forum

PORT=8080
