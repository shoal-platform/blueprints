# Postgres connection. Server creates the database + table if missing.

# Option A: single connection string (takes precedence if set).
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/pastebin

# Option B: individual PG* vars.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=pastebin

PORT=8080
